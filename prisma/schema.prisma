generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Organizations & Clients ───────────────────────────────

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

// ─── Projects ──────────────────────────────────────────────

model Project {
  id        String   @id @default(cuid())
  name      String
  repoUrl     String?
  startDate   DateTime?
  endDate     DateTime?
  contractUrl String?
  status      String   @default("active") // active, paused, completed, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // GitHub integration
  githubRepoOwner    String?
  githubRepoName     String?
  githubDefaultBranch String @default("main")

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  pmId String?
  pm   Member? @relation("ProjectPM", fields: [pmId], references: [id], onDelete: SetNull)

  projectSquads   ProjectSquad[]
  sprints         Sprint[]
  tasks           Task[]
  designSessions  DesignSession[]
  guidelines      ProjectGuideline[]
  projectReviews  MeetingProjectReview[]
  wikiSections    ProjectWikiSection[]
}

// ─── Squads & Members ──────────────────────────────────────

model Squad {
  id   String @id @default(cuid())
  name String

  projectSquads ProjectSquad[]
  members       SquadMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectSquad {
  id        String @id @default(cuid())
  projectId String
  squadId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  squad   Squad   @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([projectId, squadId])
}

model Member {
  id             String  @id @default(cuid())
  name           String
  email          String?
  role           String  @default("fullstack") // ui-ux-builder, backend-qa-builder, fullstack
  githubUsername String?
  hourlyCost     Float   @default(0)
  fpCapacity     Int     @default(125) // function points per sprint

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  squadMemberships       SquadMember[]
  taskAssignments        TaskAssignment[]
  designSessions         DesignSession[]
  sessionParticipations  DesignSessionParticipant[]
  projectsPM             Project[]            @relation("ProjectPM")
  meetingActions         MeetingActionItem[]
  meetingReviews         MeetingProjectReview[]
}

model SquadMember {
  id       String @id @default(cuid())
  squadId  String
  memberId String

  squad  Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([squadId, memberId])
}

// ─── Agents ────────────────────────────────────────────────

model Agent {
  id                String @id @default(cuid())
  name              String
  model             String // claude-sonnet-4, gpt-4o, etc
  costPerInputToken  Float  @default(0)
  costPerOutputToken Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskAssignments TaskAssignment[]
}

// ─── Sprints ───────────────────────────────────────────────

model Sprint {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("planning") // planning, active, completed

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  // Deploy tracking
  deployedToStagingAt    DateTime?
  deployedToProductionAt DateTime?
  deploys                SprintDeploy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Tasks ─────────────────────────────────────────────────

model Task {
  id         String  @id @default(cuid())
  title      String
  description String?
  reference  String  @unique // TASK-001, TASK-002, etc
  status     String  @default("backlog") // backlog, todo, in_progress, review, changes_requested, approved, staging, merge_conflict, staging_failed, done
  complexity String  @default("medium") // trivial, low, medium, high
  scope      String  @default("small") // micro, small, medium, large
  priority     Int     @default(0)
  functionPoints Int?  // FP — auto-suggested from scope×complexity, editable
  type         String  @default("feature") // setup, feature, component, seed, bugfix, refactor
  dependencies String? // JSON array of task references: ["TASK-001", "TASK-003"]
  dueDate      DateTime? // prazo de entrega

  // Execution mode
  executionMode String @default("manual") // agent, manual

  // GitHub integration
  githubIssueNumber Int?
  githubBranchName  String?
  githubPrNumber    Int?
  githubPrUrl       String?
  mergeAttempts     Int     @default(0)
  lastMergeError    String?

  // Task specs (generated by AI, refined by human)
  acceptanceCriteria String? // JSON array of strings
  businessContext    String?
  technicalNotes     String?
  outOfScope         String? // JSON array of strings
  uiGuidance         String?
  designSessionId    String? // which session generated this task

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  assignments TaskAssignment[]
  iterations  TaskIteration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAssignment {
  id     String @id @default(cuid())
  taskId String

  memberId String?
  agentId  String?

  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: Cascade)
  agent  Agent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  designSessionItemId String?
  designSessionItem   DesignSessionItem? @relation(fields: [designSessionItemId], references: [id], onDelete: SetNull)
}

// ─── Design Sessions ──────────────────────────────────────

model DesignSession {
  id          String   @id @default(cuid())
  projectId   String
  type        String   @default("inception") // inception, continuous_improvement
  status      String   @default("draft") // draft, in_progress, completed, cancelled
  title       String
  description String?
  currentStep Int      @default(0)
  totalSteps  Int      @default(7)
  scheduledAt DateTime?
  completedAt DateTime?
  actualDurationMin Int?
  createdBy   String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByMember Member? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  participants DesignSessionParticipant[]
  stepData     DesignSessionStepData[]
  items        DesignSessionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DesignSessionParticipant {
  id            String  @id @default(cuid())
  sessionId     String
  memberId      String?
  externalName  String?
  externalEmail String?
  externalRole  String?
  role          String  @default("observer") // facilitator, technical, stakeholder, decider, observer

  session DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member  Member?       @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

model DesignSessionStepData {
  id        String @id @default(cuid())
  sessionId String
  stepIndex Int
  stepKey   String // preparation, stakeholders, problem_analysis, scope, features, technical, etc
  data      String @default("{}") // JSON stored as text (SQLite)

  session DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([sessionId, stepKey])
}

model DesignSessionItem {
  id          String  @id @default(cuid())
  sessionId   String
  title       String
  description String?
  type        String  @default("feature") // feature, bugfix, improvement, rule, constraint
  priority    String  @default("should") // must, should, could, wont
  sourceStep  String?
  aiGenerated Boolean @default(false)
  orderIndex  Int     @default(0)

  session DesignSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  taskAssignments TaskAssignment[]
}

// ─── Task Iterations (coding cycles) ─────────────────────

model TaskIteration {
  id               String    @id @default(cuid())
  taskId           String
  number           Int
  type             String    @default("initial") // initial, revision, merge_fix
  trigger          String    @default("system") // system, review_feedback, merge_conflict
  promptSent       String?
  resultSummary    String?
  commitSha        String?
  costInputTokens  Int       @default(0)
  costOutputTokens Int       @default(0)
  success          Boolean   @default(false)
  errorLog         String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Sprint Deploys ───────────────────────────────────────

model SprintDeploy {
  id            String    @id @default(cuid())
  sprintId      String
  environment   String    @default("staging") // staging, production
  status        String    @default("pending") // pending, deploying, success, failed, rolled_back
  tasksIncluded String    @default("[]") // JSON array of task IDs
  tasksFailed   String    @default("[]") // JSON array of {taskId, error}
  triggeredBy   String?
  commitSha     String?
  errorLog      String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
}

// ─── Project Guidelines ───────────────────────────────────

model ProjectGuideline {
  id        String  @id @default(cuid())
  projectId String
  category  String  // design, security, libraries, icons, rate-limit, conventions, architecture
  title     String
  content   String  // markdown instructions
  isDefault Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, category])
}

// ─── Weekly Meetings ──────────────────────────────────────

model WeeklyMeeting {
  id     String   @id @default(cuid())
  date   DateTime
  status String   @default("scheduled") // scheduled, in_progress, done
  notes  String?

  projectReviews MeetingProjectReview[]
  actionItems    MeetingActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingProjectReview {
  id              String @id @default(cuid())
  meetingId       String
  projectId       String
  memberId        String // the PM reporting
  nextSteps       String?
  sprintHealth    String @default("healthy") // healthy, attention, critical
  attentionPoints String?
  additionalNotes String?
  order           Int    @default(0)

  meeting WeeklyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  actionItems MeetingActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingActionItem {
  id             String    @id @default(cuid())
  meetingId      String
  description    String
  assigneeId     String
  dueDate        DateTime?
  status         String    @default("todo") // todo, doing, done
  sourceReviewId String?
  resolvedAt     DateTime?

  meeting      WeeklyMeeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee     Member                @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  sourceReview MeetingProjectReview? @relation(fields: [sourceReviewId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Project Wiki ─────────────────────────────────────────

model ProjectWikiSection {
  id         String @id @default(cuid())
  projectId  String
  sectionKey String // sponsors, links, success_indicators, objectives, scope
  title      String
  data       String @default("[]") // JSON stored as text (SQLite)
  order      Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, sectionKey])
}
