# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# sqlite
*.db
*.db-journal

# local agent/IDE tooling
/.agents/
/.claude/
/.trae/
/skills-lock.json

# supabase local
/supabase/.temp/

# session inputs (confidential client docs, local-only)
/zelar-inputs/
/*-inputs/

# local backups (session content snapshots, large md/json files)
/.local-backups/
